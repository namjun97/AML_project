# ──────────────────────────────────────────────────────────────────────
# AML Project — 환경변수 템플릿
# 이 파일을 복사해 .env 를 만들고 실제 값을 채워 넣으세요.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────

# ── Groq LLM API ──────────────────────────────────────────────────────
# 발급: https://console.groq.com
GROQ_API_KEY=

# ── Neo4j (GraphRAG) ──────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ── Ollama (로컬 LLM · 임베딩) ────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── LangSmith (LangChain 모니터링) ────────────────────────────────────
# 발급: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=aml-project
